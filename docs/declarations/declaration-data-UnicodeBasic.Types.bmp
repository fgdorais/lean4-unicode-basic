alCategory","kind":"instance","docLink":"./UnicodeBasic/Types.html#Unicode.instDecidableEqMajorGeneralCategory","doc":""},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/90dce4f5c3deccd241e72c2ba3fea2178b295dbd/UnicodeBasic/Types.lean#L102-L102","name":"Unicode.instInhabitedMajorGeneralCategory","kind":"instance","docLink":"./UnicodeBasic/Types.html#Unicode.instInhabitedMajorGeneralCategory","doc":""},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/90dce4f5c3deccd241e72c2ba3fea2178b295dbd/UnicodeBasic/Types.lean#L100-L101","name":"Unicode.MajorGeneralCategory.other","kind":"ctor","docLink":"./UnicodeBasic/Types.html#Unicode.MajorGeneralCategory.other","doc":"(`C`) Other "},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/90dce4f5c3deccd241e72c2ba3fea2178b295dbd/UnicodeBasic/Types.lean#L98-L99","name":"Unicode.MajorGeneralCategory.separator","kind":"ctor","docLink":"./UnicodeBasic/Types.html#Unicode.MajorGeneralCategory.separator","doc":"(`Z`) Separator "},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/90dce4f5c3deccd241e72c2ba3fea2178b295dbd/UnicodeBasic/Types.lean#L96-L97","name":"Unicode.MajorGeneralCategory.symbol","kind":"ctor","docLink":"./UnicodeBasic/Types.html#Unicode.MajorGeneralCategory.symbol","doc":"(`S`) Symbol "},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/90dce4f5c3deccd241e72c2ba3fea2178b295dbd/UnicodeBasic/Types.lean#L94-L95","name":"Unicode.MajorGeneralCategory.punctuation","kind":"ctor","docLink":"./UnicodeBasic/Types.html#Unicode.MajorGeneralCategory.punctuation","doc":"(`P`) Punctuation "},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/90dce4f5c3deccd241e72c2ba3fea2178b295dbd/UnicodeBasic/Types.lean#L92-L93","name":"Unicode.MajorGeneralCategory.number","kind":"ctor","docLink":"./UnicodeBasic/Types.html#Unicode.MajorGeneralCategory.number","doc":"(`N`) Number "},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/90dce4f5c3deccd241e72c2ba3fea2178b295dbd/UnicodeBasic/Types.lean#L90-L91","name":"Unicode.MajorGeneralCategory.mark","kind":"ctor","docLink":"./UnicodeBasic/Types.html#Unicode.MajorGeneralCategory.mark","doc":"(`M`) Mark "},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/90dce4f5c3deccd241e72c2ba3fea2178b295dbd/UnicodeBasic/Types.lean#L88-L89","name":"Unicode.MajorGeneralCategory.letter","kind":"ctor","docLink":"./UnicodeBasic/Types.html#Unicode.MajorGeneralCategory.letter","doc":"(`L`) Letter "},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/90dce4f5c3deccd241e72c2ba3fea2178b295dbd/UnicodeBasic/Types.lean#L87-L102","name":"Unicode.MajorGeneralCategory","kind":"inductive","docLink":"./UnicodeBasic/Types.html#Unicode.MajorGeneralCategory","doc":"Major general category (`L`, `M`, `N`, `P`, `S`, `Z`, `C`)\n\nUnicode property: `General_Category` "},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/90dce4f5c3deccd241e72c2ba3fea2178b295dbd/UnicodeBasic/Types.lean#L75-L78","name":"Unicode.ofHexString!","kind":"def","docLink":"./UnicodeBasic/Types.html#Unicode.ofHexString!","doc":"Get code point from hexadecimal string representation\n\nFor convenience, the `U+` prefix may be omitted and lowercase hexadecimal\ndigits are accepted.\n"},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/90dce4f5c3deccd241e72c2ba3fea2178b295dbd/UnicodeBasic/Types.lean#L58-L72","name":"Unicode.ofHexString?.hexValue?","kind":"def","docLink":"./UnicodeBasic/Types.html#Unicode.ofHexString?.hexValue?","doc":"Get value of hex digit "},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/90dce4f5c3deccd241e72c2ba3fea2178b295dbd/UnicodeBasic/Types.lean#L47-L72","name":"Unicode.ofHexString?","kind":"def","docLink":"./UnicodeBasic/Types.html#Unicode.ofHexString?","doc":"Get code point from hexadecimal string representation\n\nFor convenience, the `U+` prefix may be omitted and lowercase hexadecimal\ndigits are accepted.\n"},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/90dce4f5c3deccd241e72c2ba3fea2178b295dbd/UnicodeBasic/Types.lean#L39-L40","name":"Unicode.toHexString","kind":"def","docLink":"./UnicodeBasic/Types.html#Unicode.toHexString","doc":"Hexadecimal string representation of a code point\n\nPrefix `U+` followed by at least four uppercase hexadecimal digits\n(e.g. `U+0123` and `U+4B0A1` but neither `U+123` nor `U+4b0a1`).\n"},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/90dce4f5c3deccd241e72c2ba3fea2178b295dbd/UnicodeBasic/Types.lean#L21-L31","name":"Unicode.toHexStringAux","kind":"def","docLink":"./UnicodeBasic/Types.html#Unicode.toHexStringAux","doc":"Hexadecimal string representation of a code point\n\nSame as `toHexString` but without the `U+` prefix. "},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/90dce4f5c3deccd241e72c2ba3fea2178b295dbd/UnicodeBasic/Types.lean#L16-L16","name":"Unicode.max","kind":"def","docLink":"./UnicodeBasic/Types.html#Unicode.max","doc":"Maximum valid code point value "},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/90dce4f5c3deccd241e72c2ba3fea2178b295dbd/UnicodeBasic/Types.lean#L11-L11","name":"Char.mkUnsafe","kind":"def","docLink":"./UnicodeBasic/Types.html#Char.mkUnsafe","doc":"Low-level conversion from `UInt32` to `Char` (*unsafe*)\n\nThis function translates to a no-op in the compiler. However, it does not\ncheck whether the `UInt32` code is a valid `Char` value. Only use where it's\nknown for external reasons that the code is valid. "},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/90dce4f5c3deccd241e72c2ba3fea2178b295dbd/UnicodeBasic/Types.lean#L1-L1","name":"Unicode.DecompositionMapping.mk","kind":"ctor","docLink":"./UnicodeBasic/Types.html#Unicode.DecompositionMapping.mk","doc":""},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/90dce4f5c3deccd241e72c2ba3fea2178b295dbd/UnicodeBasic/Types.lean#L1-L1","name":"Unicode.GeneralCategory.mk","kind":"ctor","docLink":"./UnicodeBasic/Types.html#Unicode.GeneralCategory.mk","doc":""}]}