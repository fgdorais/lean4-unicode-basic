lCategory\"><span class=\"name\">Unicode</span>.<span class=\"name\">getGeneralCategory</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(char : <a href=\"./Init/Prelude.html#Char\">Char</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./UnicodeBasic/Types.html#Unicode.GeneralCategory\">Unicode.GeneralCategory</a></div></div>"},{"info":{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic#L87-L92","name":"Unicode.isBidiControl","line":87,"kind":"def","docLink":"./UnicodeBasic.html#Unicode.isBidiControl","doc":"Check if bidirectional control character\n\nUnicode property: `Bidi_Control` "},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./UnicodeBasic.html#Unicode.isBidiControl\"><span class=\"name\">Unicode</span>.<span class=\"name\">isBidiControl</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(char : <a href=\"./Init/Prelude.html#Char\">Char</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Bool\">Bool</a></div></div>"},{"info":{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic#L80-L81","name":"Unicode.isBidiMirrored","line":80,"kind":"def","docLink":"./UnicodeBasic.html#Unicode.isBidiMirrored","doc":"Check if bidirectional mirrored character\n\nUnicode property: `Bidi_Mirrored` "},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./UnicodeBasic.html#Unicode.isBidiMirrored\"><span class=\"name\">Unicode</span>.<span class=\"name\">isBidiMirrored</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(char : <a href=\"./Init/Prelude.html#Char\">Char</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Bool\">Bool</a></div></div>"},{"info":{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic#L73-L74","name":"Unicode.getBidiClass","line":73,"kind":"def","docLink":"./UnicodeBasic.html#Unicode.getBidiClass","doc":"Get character bidirectional class\n\nUnicode property: `Bidi_Class` "},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./UnicodeBasic.html#Unicode.getBidiClass\"><span class=\"name\">Unicode</span>.<span class=\"name\">getBidiClass</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(char : <a href=\"./Init/Prelude.html#Char\">Char</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./UnicodeBasic/Types.html#Unicode.BidiClass\">Unicode.BidiClass</a></div></div>"},{"info":{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic#L62-L63","name":"Unicode.getName","line":62,"kind":"def","docLink":"./UnicodeBasic.html#Unicode.getName","doc":"Get character name\n\nWhen the Unicode property `Name` is empty, a unique code label is returned\nas described in Unicode Standard, section 4.8. These labels start with\n`'<'` (U+003C) and end with `'>'` (U+003E) so they are distinguishable from\nactual name values.\n\nUnicode property: `Name`\n"},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./UnicodeBasic.html#Unicode.getName\"><span class=\"name\">Unicode</span>.<span class=\"name\">getName</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(char : <a href=\"./Init/Prelude.html#Char\">Char</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#String\">String</a></div></div>"}]}