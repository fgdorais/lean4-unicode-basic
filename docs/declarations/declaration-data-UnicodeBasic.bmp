n4-unicode-basic/blob/f1c1a2239d9a6ea98469aa3d4d4814d73d4bb286/UnicodeBasic.lean#L239-L242","name":"Unicode.GeneralCategory.isSpacingMark","kind":"def","docLink":"./UnicodeBasic.html#Unicode.GeneralCategory.isSpacingMark","doc":"Check if spacing combining mark character (`Mc`)\n\nUnicode Property: `General_Category=Mc` "},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/f1c1a2239d9a6ea98469aa3d4d4814d73d4bb286/UnicodeBasic.lean#L233-L233","name":"Unicode.GeneralCategory.isMn","kind":"def","docLink":"./UnicodeBasic.html#Unicode.GeneralCategory.isMn","doc":"Check if nonspacing combining mark character (`Mn`)\n\nUnicode Property: `General_Category=Mn` "},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/f1c1a2239d9a6ea98469aa3d4d4814d73d4bb286/UnicodeBasic.lean#L227-L230","name":"Unicode.GeneralCategory.isNonspacingMark","kind":"def","docLink":"./UnicodeBasic.html#Unicode.GeneralCategory.isNonspacingMark","doc":"Check if nonspacing combining mark character (`Mn`)\n\nUnicode Property: `General_Category=Mn` "},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/f1c1a2239d9a6ea98469aa3d4d4814d73d4bb286/UnicodeBasic.lean#L221-L221","name":"Unicode.GeneralCategory.isM","kind":"def","docLink":"./UnicodeBasic.html#Unicode.GeneralCategory.isM","doc":"Check if mark character (`M`)\n\nThis is a derived category (`M = Mn | Mc | Me`).\n\nUnicode Property: `General_Category=M` "},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/f1c1a2239d9a6ea98469aa3d4d4814d73d4bb286/UnicodeBasic.lean#L215-L218","name":"Unicode.GeneralCategory.isMark","kind":"def","docLink":"./UnicodeBasic.html#Unicode.GeneralCategory.isMark","doc":"Check if mark character (`M`)\n\nThis is a derived category (`M = Mn | Mc | Me`).\n\nUnicode Property: `General_Category=M` "},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/f1c1a2239d9a6ea98469aa3d4d4814d73d4bb286/UnicodeBasic.lean#L207-L207","name":"Unicode.GeneralCategory.isLo","kind":"def","docLink":"./UnicodeBasic.html#Unicode.GeneralCategory.isLo","doc":"Check if other letter character (`Lo`)\n\nUnicode Property: `General_Category=Lo`"},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/f1c1a2239d9a6ea98469aa3d4d4814d73d4bb286/UnicodeBasic.lean#L201-L204","name":"Unicode.GeneralCategory.isOtherLetter","kind":"def","docLink":"./UnicodeBasic.html#Unicode.GeneralCategory.isOtherLetter","doc":"Check if other letter character (`Lo`)\n\nUnicode Property: `General_Category=Lo`"},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/f1c1a2239d9a6ea98469aa3d4d4814d73d4bb286/UnicodeBasic.lean#L195-L195","name":"Unicode.GeneralCategory.isLm","kind":"def","docLink":"./UnicodeBasic.html#Unicode.GeneralCategory.isLm","doc":"Check if modifier letter character (`Lm`)\n\nUnicode Property: `General_Category=Lm`"},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/f1c1a2239d9a6ea98469aa3d4d4814d73d4bb286/UnicodeBasic.lean#L189-L192","name":"Unicode.GeneralCategory.isModifierLetter","kind":"def","docLink":"./UnicodeBasic.html#Unicode.GeneralCategory.isModifierLetter","doc":"Check if modifier letter character (`Lm`)\n\nUnicode Property: `General_Category=Lm`"},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/f1c1a2239d9a6ea98469aa3d4d4814d73d4bb286/UnicodeBasic.lean#L183-L183","name":"Unicode.GeneralCategory.isLC","kind":"def","docLink":"./UnicodeBasic.html#Unicode.GeneralCategory.isLC","doc":"Check if cased letter character (`LC`)\n\nThis is a derived category (`L = Lu | Ll | Lt`).\n\nUnicode Property: `General_Category=LC` "},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/f1c1a2239d9a6ea98469aa3d4d4814d73d4bb286/UnicodeBasic.lean#L175-L180","name":"Unicode.GeneralCategory.isCasedLetter","kind":"def","docLink":"./UnicodeBasic.html#Unicode.GeneralCategory.isCasedLetter","doc":"Check if cased letter character (`LC`)\n\nThis is a derived category (`L = Lu | Ll | Lt`).\n\nUnicode Property: `General_Category=LC` "},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/f1c1a2239d9a6ea98469aa3d4d4814d73d4bb286/UnicodeBasic.lean#L167-L167","name":"Unicode.GeneralCategory.isLu","kind":"def","docLink":"./UnicodeBasic.html#Unicode.GeneralCategory.isLu","doc":"Check if uppercase letter character (`Lu`)\n\nUnicode Property: `General_Category=Lu` "},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/f1c1a2239d9a6ea98469aa3d4d4814d73d4bb286/UnicodeBasic.lean#L161-L164","name":"Unicode.GeneralCategory.isUppercaseLetter","kind":"def","docLink":"./UnicodeBasic.html#Unicode.GeneralCategory.isUppercaseLetter","doc":"Check if uppercase letter character (`Lu`)\n\nUnicode Property: `General_Category=Lu` "},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/f1c1a2239d9a6ea98469aa3d4d4814d73d4bb286/UnicodeBasic.lean#L155-L155","name":"Unicode.GeneralCategory.isLt","kind":"def","docLink":"./UnicodeBasic.html#Unicode.GeneralCategory.isLt","doc":"Check if titlecase letter character (`Lt`)\n\nUnicode Property: `General_Category=Lt` "},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/f1c1a2239d9a6ea98469aa3d4d4814d73d4bb286/UnicodeBasic.lean#L149-L152","name":"Unicode.GeneralCategory.isTitlecaseLetter","kind":"def","docLink":"./UnicodeBasic.html#Unicode.GeneralCategory.isTitlecaseLetter","doc":"Check if titlecase letter character (`Lt`)\n\nUnicode Property: `General_Category=Lt` "},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/f1c1a2239d9a6ea98469aa3d4d4814d73d4bb286/UnicodeBasic.lean#L143-L143","name":"Unicode.GeneralCategory.isLl","kind":"def","docLink":"./UnicodeBasic.html#Unicode.GeneralCategory.isLl","doc":"Check if lowercase letter character (`Ll`)\n\nUnicode Property: `General_Category=Ll` "},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/f1c1a2239d9a6ea98469aa3d4d4814d73d4bb286/UnicodeBasic.lean#L137-L140","name":"Unicode.GeneralCategory.isLowercaseLetter","kind":"def","docLink":"./UnicodeBasic.html#Unicode.GeneralCategory.isLowercaseLetter","doc":"Check if lowercase letter character (`Ll`)\n\nUnicode Property: `General_Category=Ll` "},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/f1c1a2239d9a6ea98469aa3d4d4814d73d4bb286/UnicodeBasic.lean#L131-L131","name":"Unicode.GeneralCategory.isL","kind":"def","docLink":"./UnicodeBasic.html#Unicode.GeneralCategory.isL","doc":"Check if letter character (`L`)\n\nThis is a derived category (`L = Lu | Ll | Lt | Lm | Lo`).\n\nUnicode Property: `General_Category=L` "},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/f1c1a2239d9a6ea98469aa3d4d4814d73d4bb286/UnicodeBasic.lean#L125-L128","name":"Unicode.GeneralCategory.isLetter","kind":"def","docLink":"./UnicodeBasic.html#Unicode.GeneralCategory.isLetter","doc":"Check if letter character (`L`)\n\nThis is a derived category (`L = Lu | Ll | Lt | Lm | Lo`).\n\nUnicode Property: `General_Category=L` "},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/f1c1a2239d9a6ea98469aa3d4d4814d73d4bb286/UnicodeBasic.lean#L108-L115","name":"Unicode.isInGeneralCategory","kind":"def","docLink":"./UnicodeBasic.html#Unicode.isInGeneralCategory","doc":"Check if character belongs to the general category\n\nUnicode property: `General_Category` "},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/f1c1a2239d9a6ea98469aa3d4d4814d73d4bb286/UnicodeBasic.lean#L102-L103","name":"Unicode.getGeneralCategory","kind":"def","docLink":"./UnicodeBasic.html#Unicode.getGeneralCategory","doc":"Get character general category\n\n*Caveat*: This function never returns a derived general category. Use\n`Unicode.isInGeneralCategory` to check whether a character belongs to a\ngeneral category (derived or not).\n\nUnicode property: `General_Category` "},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/f1c1a2239d9a6ea98469aa3d4d4814d73d4bb286/UnicodeBasic.lean#L83-L88","name":"Unicode.isBidiControl","kind":"def","docLink":"./UnicodeBasic.html#Unicode.isBidiControl","doc":"Check if bidirectional control character\n\nUnicode property: `Bidi_Control` "},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/f1c1a2239d9a6ea98469aa3d4d4814d73d4bb286/UnicodeBasic.lean#L77-L78","name":"Unicode.isBidiMirrored","kind":"def","docLink":"./UnicodeBasic.html#Unicode.isBidiMirrored","doc":"Check if bidirectional mirrored character\n\nUnicode property: `Bidi_Mirrored` "},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/f1c1a2239d9a6ea98469aa3d4d4814d73d4bb286/UnicodeBasic.lean#L71-L72","name":"Unicode.getBidiClass","kind":"def","docLink":"./UnicodeBasic.html#Unicode.getBidiClass","doc":"Get character bidirectional class\n\nUnicode property: `Bidi_Class` "},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/f1c1a2239d9a6ea98469aa3d4d4814d73d4bb286/UnicodeBasic.lean#L61-L62","name":"Unicode.getName","kind":"def","docLink":"./UnicodeBasic.html#Unicode.getName","doc":"Get character name\n\nWhen the Unicode property `Name` is empty, a unique code label is returned\nas described in Unicode Standard, section 4.8. These labels start with\n`'<'` (U+003C) and end with `'>'` (U+003E) so they are distinguishable from\nactual name values.\n\nUnicode property: `Name`\n"}]}