{"name":"UnicodeBasic.CharacterDatabase","instances":[{"typeNames":["Unicode.UCDStream"],"name":"Unicode.instInhabitedUCDStream","className":"Inhabited"},{"typeNames":["Unicode.UCDStream","Array","String"],"name":"Unicode.UCDStream.instStreamUCDStreamArrayString","className":"Stream"}],"imports":["Init"],"declarations":[{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/78f678ffd3a595c55b59563586c698191065e378/UnicodeBasic/CharacterDatabase.lean#L58-L59","name":"Unicode.UCDStream.instStreamUCDStreamArrayString","kind":"instance","docLink":"./UnicodeBasic/CharacterDatabase.html#Unicode.UCDStream.instStreamUCDStreamArrayString","doc":""},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/78f678ffd3a595c55b59563586c698191065e378/UnicodeBasic/CharacterDatabase.lean#L50-L56","name":"Unicode.UCDStream.next?","kind":"def","docLink":"./UnicodeBasic/CharacterDatabase.html#Unicode.UCDStream.next?","doc":"Get the next record from the `UCDStream`\n\nSpaces around field values are trimmed.\n"},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/78f678ffd3a595c55b59563586c698191065e378/UnicodeBasic/CharacterDatabase.lean#L36-L44","name":"Unicode.UCDStream.nextLine?","kind":"opaque","docLink":"./UnicodeBasic/CharacterDatabase.html#Unicode.UCDStream.nextLine?","doc":"Get the next line from the `UCDStream`\n\nLine comments are stripped and blank lines are skipped.\n"},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/78f678ffd3a595c55b59563586c698191065e378/UnicodeBasic/CharacterDatabase.lean#L29-L30","name":"Unicode.UCDStream.ofFile","kind":"def","docLink":"./UnicodeBasic/CharacterDatabase.html#Unicode.UCDStream.ofFile","doc":"Make a `UCDStream` from a file "},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/78f678ffd3a595c55b59563586c698191065e378/UnicodeBasic/CharacterDatabase.lean#L23-L26","name":"Unicode.UCDStream.ofString","kind":"def","docLink":"./UnicodeBasic/CharacterDatabase.html#Unicode.UCDStream.ofString","doc":"Make a `UCDStream` from a string "},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/78f678ffd3a595c55b59563586c698191065e378/UnicodeBasic/CharacterDatabase.lean#L18-L18","name":"Unicode.instInhabitedUCDStream","kind":"instance","docLink":"./UnicodeBasic/CharacterDatabase.html#Unicode.instInhabitedUCDStream","doc":""},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/78f678ffd3a595c55b59563586c698191065e378/UnicodeBasic/CharacterDatabase.lean#L17-L17","name":"Unicode.UCDStream.isUnihan","kind":"def","docLink":"./UnicodeBasic/CharacterDatabase.html#Unicode.UCDStream.isUnihan","doc":"`isUnihan` is true if the records are tab separated "},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/78f678ffd3a595c55b59563586c698191065e378/UnicodeBasic/CharacterDatabase.lean#L15-L18","name":"Unicode.UCDStream","kind":"structure","docLink":"./UnicodeBasic/CharacterDatabase.html#Unicode.UCDStream","doc":"Stream type for Unicode Character Database (UCD) files\n\nUnicode data files are semicolon `;` (U+003B) separated fields, except for\nUnihan files and a few others that are tab (U+0009) separated. White spaces\naround field values are not significant. Line comments are prefixed with a\nnumber sign `#` (U+0023).\n"},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/78f678ffd3a595c55b59563586c698191065e378/UnicodeBasic/CharacterDatabase.lean#L1-L1","name":"Unicode.UCDStream.mk","kind":"ctor","docLink":"./UnicodeBasic/CharacterDatabase.html#Unicode.UCDStream.mk","doc":""}]}