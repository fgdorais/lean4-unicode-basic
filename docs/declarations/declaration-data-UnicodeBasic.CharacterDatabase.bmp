{"name":"UnicodeBasic.CharacterDatabase","instances":[{"typeNames":["Unicode.UCDStream","Array","String"],"name":"Unicode.UCDStream.instStreamUCDStreamArrayString","className":"Stream"}],"imports":["Init"],"declarations":[{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/75664f7038dc639aac77ced64e15acc48a2dc036/UnicodeBasic/CharacterDatabase.lean#L57-L58","name":"Unicode.UCDStream.instStreamUCDStreamArrayString","kind":"instance","docLink":"./UnicodeBasic/CharacterDatabase.html#Unicode.UCDStream.instStreamUCDStreamArrayString","doc":""},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/75664f7038dc639aac77ced64e15acc48a2dc036/UnicodeBasic/CharacterDatabase.lean#L49-L55","name":"Unicode.UCDStream.next?","kind":"def","docLink":"./UnicodeBasic/CharacterDatabase.html#Unicode.UCDStream.next?","doc":"Get the next record from the `UCDStream`\n\nSpaces around field values are trimmed.\n"},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/75664f7038dc639aac77ced64e15acc48a2dc036/UnicodeBasic/CharacterDatabase.lean#L35-L43","name":"Unicode.UCDStream.nextLine?","kind":"opaque","docLink":"./UnicodeBasic/CharacterDatabase.html#Unicode.UCDStream.nextLine?","doc":"Get the next line from the `UCDStream`\n\nLine comments are stripped and blank lines are skipped.\n"},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/75664f7038dc639aac77ced64e15acc48a2dc036/UnicodeBasic/CharacterDatabase.lean#L28-L29","name":"Unicode.UCDStream.ofFile","kind":"def","docLink":"./UnicodeBasic/CharacterDatabase.html#Unicode.UCDStream.ofFile","doc":"Make a `UCDStream` from a file "},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/75664f7038dc639aac77ced64e15acc48a2dc036/UnicodeBasic/CharacterDatabase.lean#L22-L25","name":"Unicode.UCDStream.ofString","kind":"def","docLink":"./UnicodeBasic/CharacterDatabase.html#Unicode.UCDStream.ofString","doc":"Make a `UCDStream` from a string "},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/75664f7038dc639aac77ced64e15acc48a2dc036/UnicodeBasic/CharacterDatabase.lean#L17-L17","name":"Unicode.UCDStream.isUnihan","kind":"def","docLink":"./UnicodeBasic/CharacterDatabase.html#Unicode.UCDStream.isUnihan","doc":"`isUnihan` is true if the records are tab separated "},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/75664f7038dc639aac77ced64e15acc48a2dc036/UnicodeBasic/CharacterDatabase.lean#L15-L17","name":"Unicode.UCDStream","kind":"structure","docLink":"./UnicodeBasic/CharacterDatabase.html#Unicode.UCDStream","doc":"Stream type for Unicode Character Database (UCD) files\n\nUnicode data files are semicolon `;` (U+003B) separated fields, except for\nUnihan files and a few others that are tab (U+0009) separated. White spaces\naround field values are not significant. Line comments are prefixed with a\nnumber sign `#` (U+0023).\n"},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/75664f7038dc639aac77ced64e15acc48a2dc036/UnicodeBasic/CharacterDatabase.lean#L1-L1","name":"Unicode.UCDStream.mk","kind":"ctor","docLink":"./UnicodeBasic/CharacterDatabase.html#Unicode.UCDStream.mk","doc":""}]}