{"name":"UnicodeBasic.CharacterDatabase","instances":[{"typeNames":["Unicode.UCDStream","Array","String"],"name":"Unicode.UCDStream.instStreamUCDStreamArrayString","className":"Stream"}],"imports":["Init"],"declarations":[{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/c7360dcdfc4ef13e1accbe83280656d8348839fa/UnicodeBasic/CharacterDatabase.lean#L48-L49","name":"Unicode.UCDStream.instStreamUCDStreamArrayString","kind":"instance","docLink":"./UnicodeBasic/CharacterDatabase.html#Unicode.UCDStream.instStreamUCDStreamArrayString","doc":""},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/c7360dcdfc4ef13e1accbe83280656d8348839fa/UnicodeBasic/CharacterDatabase.lean#L40-L46","name":"Unicode.UCDStream.next?","kind":"def","docLink":"./UnicodeBasic/CharacterDatabase.html#Unicode.UCDStream.next?","doc":"Get the next record from the `UCDStream` "},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/c7360dcdfc4ef13e1accbe83280656d8348839fa/UnicodeBasic/CharacterDatabase.lean#L29-L37","name":"Unicode.UCDStream.nextLine?","kind":"opaque","docLink":"./UnicodeBasic/CharacterDatabase.html#Unicode.UCDStream.nextLine?","doc":"Get the next line from the `UCDStream`\n\nSkips blank lines and strips line comments.\n"},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/c7360dcdfc4ef13e1accbe83280656d8348839fa/UnicodeBasic/CharacterDatabase.lean#L20-L23","name":"Unicode.UCDStream.ofString","kind":"def","docLink":"./UnicodeBasic/CharacterDatabase.html#Unicode.UCDStream.ofString","doc":"Make a `UCDStream` from a string "},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/c7360dcdfc4ef13e1accbe83280656d8348839fa/UnicodeBasic/CharacterDatabase.lean#L15-L15","name":"Unicode.UCDStream.isUnihan","kind":"def","docLink":"./UnicodeBasic/CharacterDatabase.html#Unicode.UCDStream.isUnihan","doc":""},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/c7360dcdfc4ef13e1accbe83280656d8348839fa/UnicodeBasic/CharacterDatabase.lean#L14-L15","name":"Unicode.UCDStream","kind":"structure","docLink":"./UnicodeBasic/CharacterDatabase.html#Unicode.UCDStream","doc":"Stream type for Unicode Character Database (UCD)\n\nUnicode data files are semicolon (U+003B) separated fields, except for\nUnihan files and a few others that are tab (U+0009) separated. White spaces around field values\nare not significant. Line comments are prefixed with '`#`' (U+0023).\n"},{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/c7360dcdfc4ef13e1accbe83280656d8348839fa/UnicodeBasic/CharacterDatabase.lean#L1-L1","name":"Unicode.UCDStream.mk","kind":"ctor","docLink":"./UnicodeBasic/CharacterDatabase.html#Unicode.UCDStream.mk","doc":""}]}