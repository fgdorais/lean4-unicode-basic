an> : <span class=\"fn\"><a href=\"./Std/Time/Time/Unit/Second.html#Std.Time.Second.Ordinal\">Second.Ordinal</a> <a href=\"./Init/Prelude.html#Bool.true\">true</a></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Std/Time/Zoned/ZonedDateTime.html#Std.Time.ZonedDateTime\">ZonedDateTime</a></div></div>","info":{"doc":"Creates a new `ZonedDateTime` by adjusting the `second` component.\n","docLink":"./Std/Time/Zoned/ZonedDateTime.html#Std.Time.ZonedDateTime.withSeconds","kind":"def","line":448,"name":"Std.Time.ZonedDateTime.withSeconds","sourceLink":"https://github.com/leanprover/lean4/blob/68218e876d2a38b1985b8590fff244a83c321783/src/Std/Time/Zoned/ZonedDateTime.lean#L448-L454"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Time/Zoned/ZonedDateTime.html#Std.Time.ZonedDateTime.withMinutes\"><span class=\"name\">Std</span>.<span class=\"name\">Time</span>.<span class=\"name\">ZonedDateTime</span>.<span class=\"name\">withMinutes</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">dt</span> : <a href=\"./Std/Time/Zoned/ZonedDateTime.html#Std.Time.ZonedDateTime\">ZonedDateTime</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">minute</span> : <a href=\"./Std/Time/Time/Unit/Minute.html#Std.Time.Minute.Ordinal\">Minute.Ordinal</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Std/Time/Zoned/ZonedDateTime.html#Std.Time.ZonedDateTime\">ZonedDateTime</a></div></div>","info":{"doc":"Creates a new `ZonedDateTime` by adjusting the `minute` component.\n","docLink":"./Std/Time/Zoned/ZonedDateTime.html#Std.Time.ZonedDateTime.withMinutes","kind":"def","line":440,"name":"Std.Time.ZonedDateTime.withMinutes","sourceLink":"https://github.com/leanprover/lean4/blob/68218e876d2a38b1985b8590fff244a83c321783/src/Std/Time/Zoned/ZonedDateTime.lean#