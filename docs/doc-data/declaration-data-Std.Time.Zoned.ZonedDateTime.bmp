Time.ZonedDateTime\">ZonedDateTime</a></div></div>","info":{"doc":"Creates a `ZonedDateTime` from a local date given as a `Day.Offset` relative to 1970-01-01, a\n`PlainTime`, and `ZoneRules`. The day offset is interpreted as a local (civil) date, not UTC.\n","docLink":"./Std/Time/Zoned/ZonedDateTime.html#Std.Time.ZonedDateTime.ofEpochDay","kind":"def","line":485,"name":"Std.Time.ZonedDateTime.ofEpochDay","sourceLink":"https://github.com/leanprover/lean4/blob/68218e876d2a38b1985b8590fff244a83c321783/src/Std/Time/Zoned/ZonedDateTime.lean#L485-L491"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Time/Zoned/ZonedDateTime.html#Std.Time.ZonedDateTime.toEpochDay\"><span class=\"name\">Std</span>.<span class=\"name\">Time</span>.<span class=\"name\">ZonedDateTime</span>.<span class=\"name\">toEpochDay</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">date</span> : <a href=\"./Std/Time/Zoned/ZonedDateTime.html#Std.Time.ZonedDateTime\">ZonedDateTime</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Std/Time/Date/Unit/Day.html#Std.Time.Day.Offset\">Day.Offset</a></div></div>","info":{"doc":"Returns the local (civil) date of the `ZonedDateTime` as a `Day.Offset` relative to 1970-01-01.\n","docLink":"./Std/Time/Zoned/ZonedDateTime.html#Std.Time.ZonedDateTime.toEpochDay","kind":"def","line":479,"name":"Std.Time.ZonedDateTime.toEpochDay","sourceLink":"https://github.com/leanprover/lean4/blob/68218e876d2a38b1985b8590fff244a83c321783/src/Std/Time/Zoned/ZonedDateTime.lean#L479-L483"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Time/Zoned/ZonedDateTime.html#Std.Time.ZonedDateTime.inLeapYear\"><span class=\"name\">Std</span>.<span class=\"name\">Time</span>.<span class=\"name\">ZonedDateTime</span>.<span class=\"name\">i