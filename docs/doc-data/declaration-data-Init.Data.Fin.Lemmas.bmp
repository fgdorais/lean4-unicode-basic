Fin/Basic.html#Fin.castSucc\">castSucc</a></span></span> → <span class=\"fn\"><span class=\"fn\">motive</span> <span class=\"fn\"><span class=\"fn\">i</span>.<a href=\"./Init/Data/Fin/Basic.html#Fin.succ\">succ</a></span></span></span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\">(fun (<span class=\"fn\">i</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#Fin\">Fin</a> (<span class=\"fn\">n</span> <a href=\"./Init/Prelude.html#HAdd.hAdd\">+</a> <span class=\"fn\">1</span>)</span>) =&gt; <span class=\"fn\"><a href=\"./Init/Data/Fin/Lemmas.html#Fin.induction\">induction</a> <span class=\"fn\">zero</span> <span class=\"fn\">hs</span> <span class=\"fn\">i</span></span>)</span> <span class=\"fn\">0</span></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\">zero</span></div></div>","info":{"doc":"","docLink":"./Init/Data/Fin/Lemmas.html#Fin.induction_zero","kind":"theorem","line":921,"name":"Fin.induction_zero","sourceLink":"https://github.com/leanprover/lean4/blob/68218e876d2a38b1985b8590fff244a83c321783/src/Init/Data/Fin/Lemmas.lean#L921-L923"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Fin/Lemmas.html#Fin.induction.go\"><span class=\"name\">Fin</span>.<span class=\"name\">induction</span>.<span class=\"name\">go</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">n</span> : <a href=\"./Init/Prelude.html#Nat\">Nat</a>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">motive</span> : <span class=\"fn\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Fin\">Fin</a> (<span class=\"fn\">n</span> <a href=\"./Init/Prelude.html#HAdd.hAdd\">+</a> <span class=\"fn\">1</span>)</span> → <a href=\"./foundational_types.html\">Sort</a> u_1</span>}</span></span>\n<