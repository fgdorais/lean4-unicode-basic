a/NeZero.html#NeZero\">NeZero</a> <span class=\"fn\">n</span></span>]</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">x</span> : <a href=\"./Init/Data/Int/Basic.html#Int\">Int</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\">↑<span class=\"fn\">x</span></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <a href=\"./Init/Prelude.html#ite\">if</a> <span class=\"fn\">0</span> <a href=\"./Init/Prelude.html#LE.le\">≤</a> <span class=\"fn\">x</span> <a href=\"./Init/Prelude.html#ite\">then</a> <span class=\"fn\"><a href=\"./Init/Data/Fin/Basic.html#Fin.ofNat\">Fin.ofNat</a> <span class=\"fn\">n</span> <span class=\"fn\"><span class=\"fn\">x</span>.<a href=\"./Init/Data/Int/Basic.html#Int.natAbs\">natAbs</a></span></span> <a href=\"./Init/Prelude.html#ite\">else</a> <a href=\"./Init/Prelude.html#Neg.neg\">-</a><span class=\"fn\"><a href=\"./Init/Data/Fin/Basic.html#Fin.ofNat\">Fin.ofNat</a> <span class=\"fn\">n</span> <span class=\"fn\"><span class=\"fn\">x</span>.<a href=\"./Init/Data/Int/Basic.html#Int.natAbs\">natAbs</a></span></span></div></div>","info":{"doc":"","docLink":"./Init/Data/Fin/Lemmas.html#Fin.intCast_def","kind":"theorem","line":156,"name":"Fin.intCast_def","sourceLink":"https://github.com/leanprover/lean4/blob/68218e876d2a38b1985b8590fff244a83c321783/src/Init/Data/Fin/Lemmas.lean#L156-L157"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Fin/Lemmas.html#Fin.IntCast.instIntCast\"><span class=\"name\">Fin</span>.<span class=\"name\">IntCast</span>.<span class=\"name\">instIntCast</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">n</span> : <a href=\"./Init/Prelude.html#Nat\">Nat</a>)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Data/NeZero.html#NeZero\">NeZero</a> <span class=\"fn\">n</span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Data/Int/Basic.html#IntCast\">IntCast</a> <span class=\"fn\">(<a href=\"./Init/Prelude.html#Fin\">Fin</a> <span class=\"fn\">n</span>)</span></span></div></div>","info":{"doc":"This is not a global instance, but may be activated locally via `open Fin.IntCast in ...`.\n\nSee the doc-string for `Fin.NatCast.instNatCast` for more details.\n","docLink":"./Init/Data/Fin/Lemmas.html#Fin.IntCast.instIntCast","kind":"def","line":142,"name":"Fin.IntCast.instIntCast","sourceLink":"https://github.com/leanprover/lean4/blob/68218e876d2a38b1985b8590fff244a83c321783/src/Init/Data/Fin/Lemmas.lean#L142-L149"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Fin/Lemmas.html#Fin.intCast\"><span class=\"name\">Fin</span>.<span class=\"name\">intCast</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">n</span> : <a href=\"./Init/Prelude.html#Nat\">Nat</a>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Data/NeZero.html#NeZero\">NeZero</a> <span class=\"fn\">n</span></span>]</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">a</span> : <a href=\"./Init/Data/Int/Basic.html#Int\">Int</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Fin\">Fin</a> <span class=\"fn\">n</span></span></div></div>","info":{"doc":"","docLink":"./Init/Data/Fin/Lemmas.html#Fin.intCast","kind":"def","line":134,"name":"Fin.intCast","sourceLink":"https://github.com/leanprover/lean4/blob/68218e876d2a38b1985b8590fff244a83c321783/src/Init/Data/Fin/Lemmas.lean#L134-L138"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Fin/Lemmas.html#Fin.NatCast.instNatCast\"><span class=\"name\">Fin</span>.<span class=\"name\">NatCast</span>.<span class=\"name\">instNatCast</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">n</span> : <a href=\"./Init/Prelude.html#Nat\">Nat</a>)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Data/NeZero.html#NeZero\">NeZero</a> <span class=\"fn\">n</span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Data/Cast.html#NatCast\">NatCast</a> <span class=\"fn\">(<a href=\"./Init/Prelude.html#Fin\">Fin</a> <span class=\"fn\">n</span>)</span></span></div></div>","info":{"doc":"This is not a global instance, but may be activated locally via `open Fin.NatCast in ...`.\n\nThis is not an instance because the `binop%` elaborator assumes that\nthere are no non-trivial coercion loops,\nbut this introduces a coercion from `Nat` to `Fin n` and back.\n\nNon-trivial loops lead to undesirable and counterintuitive elaboration behavior.\nFor example, for `x : Fin k` and `n : Nat`,\nit causes `x < n` to be elaborated as `x < ↑n` rather than `↑x < n`,\nsilently introducing wraparound arithmetic.\n","docLink":"./Init/Data/Fin/Lemmas.html#Fin.NatCast.instNatCast","kind":"def","line":114,"name":"Fin.NatCast.instNatCast","sourceLink":"https://github.com/leanprover/lean4/blob/68218e876d2a38b1985b8590fff244a83c321783/src/Init/Data/Fin/Lemmas.lean#L114-L128"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Fin/Lemmas.html#Fin.dite_val\"><span class=\"name\">Fin</span>.<span class=\"name\">dite_val</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">n</span> : <a href=\"./Init/Prelude.html#Nat\">Nat</a>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">c</span> : <a href=\"./foundational_types.html\">Prop</a>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Prelude.html#Decidable\">Decidable</a> <span class=\"fn\">c</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">x </span><span class=\"fn\">y</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#Fin\">Fin</a> <span class=\"fn\">n</span></span>}</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\">↑(<a href=\"./Init/Prelude.html#ite\">if</a> <span class=\"fn\">c</span> <a href=\"./Init/Prelude.html#ite\">then</a> <span class=\"fn\">x</span> <a href=\"./Init/Prelude.html#ite\">else</a> <span class=\"fn\">y</span>)</span> <a href=\"./Init/Prelude.html#Eq\">=</a> <a href=\"./Init/Prelude.html#ite\">if</a> <span class=\"fn\">c</span> <a href=\"./Init/Prelude.html#ite\">then</a> <span class=\"fn\">↑<span class=\"fn\">x</span></span> <a href=\"./Init/Prelude.html#ite\">else</a> <span class=\"fn\">↑<span class=\"fn\">y</span></span></div></div>","info":{"doc":"","docLink":"./Init/Data/Fin/Lemmas.html#Fin.dite_val","kind":"theorem","line":108,"name":"Fin.dite_val","sourceLink":"https://github.com/leanprover/lean4/blob/68218e876d2a38b1985b8590fff244a83c321783/src/Init/Data/Fin/Lemmas.lean#L108-L110"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Init/Data/Fin/Lemmas.html#Fin.ite_val\"><span class=\"name\">Fin</span>.<span class=\"name\">ite_val</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">n</span> : <a href=\"./Init/Prelude.html#Nat\">Nat</a>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">c</span> : <a href=\"./foundational_types.html\">Prop</a>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Prelude.html#Decidable\">Decidable</a> <span class=\"fn\">c</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">x</span> : <span class=\"fn\"><span class=\"fn\">c</span> → <span class=\"fn\"><a href=\"./Init/Prelude.html#Fin\">Fin</a> <span class=\"fn\">n</span></span></span>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">y</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#Not\">¬</a><span class=\"fn\">c</span> → <span class=\"fn\"><a href=\"./Init/Prelude.html#Fin\">Fin</a> <span class=\"fn\">n</span></span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\">↑<span class=\"fn\">(if h : <span class=\"fn\">c</span> then <span class=\"fn\"><span class=\"fn\">x</span> <span class=\"fn\">h</span></span> else <span class=\"fn\"><span class=\"fn\">y</span> <span class=\"fn\">h</span></span>)</span></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\">if h : <span class=\"fn\">c</span> then <span class=\"fn\">↑<span class=\"fn\">(<span class=\"fn\">x</span> <span class=\"fn\">h</span>)</span></span> else <span class=\"fn\">↑<span class=\"fn\">(<span class=\"fn\">y</span> <span class=\"fn\">h</span>)</span></span></span></div></div>","info":{"doc":"","docLink":"./Init/Data/Fin/Lemmas.html#Fin.ite_val","kind":"theorem","line":104,"name":"Fin.ite_val","sourceLink":"https://github.com/leanprover/lean4/blob/68218e876d2a38b1985b8590fff244a83c321783/src/Init/Data/Fin/Lemmas.lean#L104-L106"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\