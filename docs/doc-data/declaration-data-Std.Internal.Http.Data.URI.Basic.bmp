st</span>.<span class=\"name\">ipv6</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">ipv6</span> : <a href=\"./Std/Net/Addr.html#Std.Net.IPv6Addr\">Net.IPv6Addr</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.Host\">Host</a></div></div>","info":{"doc":"An IPv6 address.\n","docLink":"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.Host.ipv6","kind":"ctor","line":214,"name":"Std.Http.URI.Host.ipv6","sourceLink":"https://github.com/leanprover/lean4/blob/3dc1a088b6d2d8eafe25a7cd7ec7b58d731bd7cc/src/Std/Internal/Http/Data/URI/Basic.lean#L214-L217"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.Host.ipv4\"><span class=\"name\">Std</span>.<span class=\"name\">Http</span>.<span class=\"name\">URI</span>.<span class=\"name\">Host</span>.<span class=\"name\">ipv4</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">ipv4</span> : <a href=\"./Std/Net/Addr.html#Std.Net.IPv4Addr\">Net.IPv4Addr</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.Host\">Host</a></div></div>","info":{"doc":"An IPv4 address.\n","docLink":"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.Host.ipv4","kind":"ctor","line":209,"name":"Std.Http.URI.Host.ipv4","sourceLink":"https://github.com/leanprover/lean4/blob/3dc1a088b6d2d8eafe25a7cd7ec7b58d731bd7cc/src/Std/Internal/Http/Data/URI/Basic.lean#L209-L212"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.Host.name\"><span class=\"name\">Std</span>.<span class=\"name\">Http</span>.<span class=\"name\">URI</span>.<span class=\"name\">Host</span>.<span class=\"name\">name</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">name</span> : <a href=\"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.DomainName\">DomainName</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.Host\">Host</a></div></div>","info":{"doc":"A domain name (lowercase-normalized).\n","docLink":"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.Host.name","kind":"ctor","line":204,"name":"Std.Http.URI.Host.name","sourceLink":"https://github.com/leanprover/lean4/blob/3dc1a088b6d2d8eafe25a7cd7ec7b58d731bd7cc/src/Std/Internal/Http/Data/URI/Basic.lean#L204-L207"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">inductive</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.Host\"><span class=\"name\">Std</span>.<span class=\"name\">Http</span>.<span class=\"name\">URI</span>.<span class=\"name\">Host</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a></div></div>","info":{"doc":"Host component of a URI, supporting domain names and IP addresses.\n\nReference: https://www.rfc-editor.org/rfc/rfc3986.html#section-3.2.2\n","docLink":"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.Host","kind":"inductive","line":198,"name":"Std.Http.URI.Host","sourceLink":"https://github.com/leanprover/lean4/blob/3dc1a088b6d2d8eafe25a7cd7ec7b58d731bd7cc/src/Std/Internal/Http/Data/URI/Basic.lean#L198-L218"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.DomainName.ofString?\"><span class=\"name\">Std</span>.<span class=\"name\">Http</span>.<span class=\"name\">URI</span>.<span class=\"name\">DomainName</span>.<span class=\"name\">ofString?</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">s</span> : <a href=\"./Init/Prelude.html#String\">String</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Option\">Option</a> <a href=\"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.DomainName\">DomainName</a></span></div></div>","info":{"doc":"Attempts to create a normalized domain name from a string.\nReturns `none` if the name is empty, longer than 255 characters, or any label violates DNS label\nconstraints.\n","docLink":"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.DomainName.ofString?","kind":"def","line":182,"name":"Std.Http.URI.DomainName.ofString?","sourceLink":"https://github.com/leanprover/lean4/blob/3dc1a088b6d2d8eafe25a7cd7ec7b58d731bd7cc/src/Std/Internal/Http/Data/URI/Basic.lean#L182-L194"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.DomainName\"><span class=\"name\">Std</span>.<span class=\"name\">Http</span>.<span class=\"name\">URI</span>.<span class=\"name\">DomainName</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a></div></div>","info":{"doc":"A domain name represented as a validated, lowercase-normalized string.\nOnly ASCII alphanumeric characters, hyphens, and dots are allowed.\nEach label cannot start or end with `-` and is limited to 63 characters.\nInternationalized domain names must be converted to punycode before use.\n\nReference: https://www.rfc-editor.org/rfc/rfc3986.html#section-3.2.2\n","docLink":"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.DomainName","kind":"def","line":170,"name":"Std.Http.URI.DomainName","sourceLink":"https://github.com/leanprover/lean4/blob/3dc1a088b6d2d8eafe25a7cd7ec7b58d731bd7cc/src/Std/Internal/Http/Data/URI/Basic.lean#L170-L178"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.IsValidDomainName\"><span class=\"name\">Std</span>.<span class=\"name\">Http</span>.<span class=\"name\">URI</span>.<span class=\"name\">IsValidDomainName</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">s</span> : <a href=\"./Init/Prelude.html#String\">String</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Prop</a></div></div>","info":{"doc":"Proposition that asserts `s` is a valid dot-separated domain name.\nEach label must satisfy `IsValidDomainLabel`, and the full name must be at most 255 characters.\n","docLink":"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.IsValidDomainName","kind":"def","line":162,"name":"Std.Http.URI.IsValidDomainName","sourceLink":"https://github.com/leanprover/lean4/blob/3dc1a088b6d2d8eafe25a7cd7ec7b58d731bd7cc/src/Std/Internal/Http/Data/URI/Basic.lean#L162-L168"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.isValidDomainLabel\"><span class=\"name\">Std</span>.<span class=\"name\">Http</span>.<span class=\"name\">URI</span>.<span class=\"name\">isValidDomainLabel</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">s</span> : <a href=\"./Init/Prelude.html#String\">String</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Bool\">Bool</a></div></div>","info":{"doc":"Checks whether a single domain label is valid. A label must be non-empty, contain only ASCII\nalphanumeric characters and `-`, cannot start or end with `-`, and must be at most 63 characters.\n\nReferences:\n* https://www.rfc-editor.org/rfc/rfc1034.html#section-3.5\n* https://www.rfc-editor.org/rfc/rfc1123.html#section-2.1\n","docLink":"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.isValidDomainLabel","kind":"def","line":147,"name":"Std.Http.URI.isValidDomainLabel","sourceLink":"https://github.com/leanprover/lean4/blob/3dc1a088b6d2d8eafe25a7cd7ec7b58d731bd7cc/src/Std/Internal/Http/Data/URI/Basic.lean#L147-L160"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.UserInfo.password?\"><span class=\"name\">Std</span>.<span class=\"name\">Http</span>.<span class=\"name\">URI</span>.<span class=\"name\">UserInfo</span>.<span class=\"name\">password?</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">ui</span> : <a href=\"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.UserInfo\">UserInfo</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Option\">Option</a> <a href=\"./Init/Prelude.html#String\">String</a></span></div></div>","info":{"doc":"Returns the decoded password when present, or `none` if absent or decoding fails UTF-8 validation.\n","docLink":"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.UserInfo.password?","kind":"def","line":138,"name":"Std.Http.URI.UserInfo.password?","sourceLink":"https://github.com/leanprover/lean4/blob/3dc1a088b6d2d8eafe25a7cd7ec7b58d731bd7cc/src/Std/Internal/Http/Data/URI/Basic.lean#L138-L143"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.UserInfo.username?\"><span class=\"name\">Std</span>.<span class=\"name\">Http</span>.<span class=\"name\">URI</span>.<span class=\"name\">UserInfo</span>.<span class=\"name\">username?</