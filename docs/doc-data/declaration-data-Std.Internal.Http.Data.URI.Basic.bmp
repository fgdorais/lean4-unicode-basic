8d731bd7cc/src/Std/Internal/Http/Data/URI/Basic.lean#L395-L395"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.instInhabitedQuery\"><span class=\"name\">Std</span>.<span class=\"name\">Http</span>.<span class=\"name\">URI</span>.<span class=\"name\">instInhabitedQuery</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Inhabited\">Inhabited</a> <a href=\"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.Query\">Query</a></span></div></div>","info":{"doc":"","docLink":"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.instInhabitedQuery","kind":"instance","line":395,"name":"Std.Http.URI.instInhabitedQuery","sourceLink":"https://github.com/leanprover/lean4/blob/3dc1a088b6d2d8eafe25a7cd7ec7b58d731bd7cc/src/Std/Internal/Http/Data/URI/Basic.lean#L395-L395"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.instReprQuery\"><span class=\"name\">Std</span>.<span class=\"name\">Http</span>.<span class=\"name\">URI</span>.<span class=\"name\">instReprQuery</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Data/Repr.html#Repr\">Repr</a> <a href=\"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.Query\">Query</a></span></div></div>","info":{"doc":"","docLink":"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.instReprQuery","kind":"instance","line":395,"name":"Std.Http.URI.instReprQuery","sourceLink":"https://github.com/leanprover/lean4/blob/3dc1a088b6d2d8eafe25a7cd7ec7b58d731bd7cc/src/Std/Internal/Http/Data/URI/Basic.lean#L395-L395"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.Query\"><span class=\"name\">Std</span>.<span class=\"name\">Http</span>.<span class=\"name\">URI</span>.<span class=\"name\">Query</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a></div></div>","info":{"doc":"Query string represented as an array of key-value pairs. Both keys and values are stored as\n`EncodedQueryParam` for proper application/x-www-form-urlencoded encoding. Values are optional to\nsupport parameters without values (e.g., \"?flag\"). Order is preserved based on insertion order.\n\nReference: https://www.rfc-editor.org/rfc/rfc3986.html#section-3.4\n","docLink":"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.Query","kind":"def","line":386,"name":"Std.Http.URI.Query","sourceLink":"https://github.com/leanprover/lean4/blob/3dc1a088b6d2d8eafe25a7cd7ec7b58d731bd7cc/src/Std/Internal/Http/Data/URI/Basic.lean#L386-L395"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.Path.toDecodedSegments\"><span class=\"name\">Std</span>.<span class=\"name\">Http</span>.<span class=\"name\">URI</span>.<span class=\"name\">Path</span>.<span class=\"name\">toDecodedSegments</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">p</span> : <a href=\"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.Path\">Path</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Array\">Array</a> <a href=\"./Init/Prelude.html#String\">String</a></span></div></div>","info":{"doc":"Returns the path segments as decoded strings.\nSegments that cannot be decoded as UTF-8 are returned as their raw encoded form.\n","docLink":"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.Path.toDecodedSegments","kind":"def","line":376,"name":"Std.Http.URI.Path.toDecodedSegments","sourceLink":"https://github.com/leanprover/lean4/blob/3dc1a088b6d2d8eafe25a7cd7ec7b58d731bd7cc/src/Std/Internal/Http/Data/URI/Basic.lean#L376-L382"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.Path.normalize\"><span class=\"name\">Std</span>.<span class=\"name\">Http</span>.<span class=\"name\">URI</span>.<span class=\"name\">Path</span>.<span class=\"name\">normalize</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">p</span> : <a href=\"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.Path\">Path</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.Path\">Path</a></div></div>","info":{"doc":"Removes dot segments from the path according to RFC 3986 Section 5.2.4. This handles \".\"\n(current directory) and \"..\" (parent directory) segments.\n","docLink":"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.Path.normalize","kind":"def","line":355,"name":"Std.Http.URI.Path.normalize","sourceLink":"https://github.com/leanprover/lean4/blob/3dc1a088b6d2d8eafe25a7cd7ec7b58d731bd7cc/src/Std/Internal/Http/Data/URI/Basic.lean#L355-L374"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.Path.appendEncoded\"><span class=\"name\">Std</span>.<span class=\"name\">Http</span>.<span class=\"name\">URI</span>.<span class=\"name\">Path</span>.<span class=\"name\">appendEncoded</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">p</span> : <a href=\"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.Path\">Path</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">segment</span> : <a href=\"./Std/Internal/Http/Data/URI/Encoding.html#Std.Http.URI.EncodedSegment\">EncodedSegment</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.Path\">Path</a></div></div>","info":{"doc":"Appends an already-encoded segment to the path.\n","docLink":"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.Path.appendEncoded","kind":"def","line":349,"name":"Std.Http.URI.Path.appendEncoded","sourceLink":"https://github.com/leanprover/lean4/blob/3dc1a088b6d2d8eafe25a7cd7ec7b58d731bd7cc/src/Std/Internal/Http/Data/URI/Basic.lean#L349-L353"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.Path.append\"><span class=\"name\">Std</span>.<span class=\"name\">Http</span>.<span class=\"name\">URI</span>.<span class=\"name\">Path</span>.<span class=\"name\">append</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">p</span> : <a href=\"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.Path\">Path</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">segment</span> : <a href=\"./Init/Prelude.html#String\">String</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.Path\">Path</a></div></div>","info":{"doc":"Appends a single segment to the path. The segment will be percent-encoded.\n","docLink":"./Std/Internal/Http/Data/URI/Basic.html#Std.Http.URI.Path.append","kind":"def","line":343,"name":"Std.Http.URI.Path.append","sourceLink":"https://github.com/leanprover/lean4/blob/3dc1a088b6d2d8eafe25a7cd7ec7b58d731bd7cc/src/Std/Internal/Http/Data/URI/Basic.lean#L343-L347"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"dec