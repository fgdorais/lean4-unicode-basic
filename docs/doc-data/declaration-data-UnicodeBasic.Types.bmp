ithub.com/fgdorais/lean4-unicode-basic/blob/92e7648d19f24127919bcf3ff86eb0a43388824c/UnicodeBasic/Types.lean#L66-L80","name":"Unicode.ofHexString?.hexValue?","line":66,"kind":"def","docLink":"./UnicodeBasic/Types.html#Unicode.ofHexString?.hexValue?","doc":"Get value of hex digit "},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./UnicodeBasic/Types.html#Unicode.ofHexString?.hexValue?\"><span class=\"name\">Unicode</span>.<span class=\"name\">ofHexString?</span>.<span class=\"name\">hexValue?</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">dgt</span> : <a href=\"./Init/Prelude.html#Char\">Char</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Option\">Option</a> <a href=\"./Init/Prelude.html#UInt32\">UInt32</a></span></div></div>"},{"info":{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/92e7648d19f24127919bcf3ff86eb0a43388824c/UnicodeBasic/Types.lean#L50-L80","name":"Unicode.ofHexString?","line":50,"kind":"def","docLink":"./UnicodeBasic/Types.html#Unicode.ofHexString?","doc":"Get code point from hexadecimal string representation\n\nFor convenience, the `U+` prefix may be omitted and lowercase hexadecimal\ndigits are accepted.\n"},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./UnicodeBasic/Types.html#Unicode.ofHexString?\"><span class=\"name\">Unicode</span>.<span class=\"name\">ofHexString?</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">str</span> : <a href=\"./Init/Prelude.html#Substring\">Substring</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Option\">Option</a> <a href=\"./Init/Prelude.html#UInt32\">UInt32</a></span></div></div>"},{"info":{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/92e7648d19f24127919bcf3ff86eb0a43388824c/UnicodeBasic/Types.lean#L41-L48","name":"Unicode.toHexString","line":41,"kind":"def","docLink":"./UnicodeBasic/Types.html#Unicode.toHexString","doc":"Hexadecimal string representation of a code point\n\nPrefix `U+` followed by at least four uppercase hexadecimal digits\n(e.g. `U+0123` and `U+4B0A1` but neither `U+123` nor `U+4b0a1`).\n"},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./UnicodeBasic/Types.html#Unicode.toHexString\"><span class=\"name\">Unicode</span>.<span class=\"name\">toHexString</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">code</span> : <a href=\"./Init/Prelude.html#UInt32\">UInt32</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#String\">String</a></div></div>"},{"info":{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/92e7648d19f24127919bcf3ff86eb0a43388824c/UnicodeBasic/Types.lean#L26-L39","name":"Unicode.toHexStringAux","line":26,"kind":"def","docLink":"./UnicodeBasic/Types.html#Unicode.toHexStringAux","doc":"Hexadecimal string representation of a code point\n\nSame as `toHexString` but without the `U+` prefix. "},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./UnicodeBasic/Types.html#Unicode.toHexStringAux\"><span class=\"name\">Unicode</span>.<span class=\"name\">toHexStringAux</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">code</span> : <a href=\"./Init/Prelude.html#UInt32\">UInt32</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#String\">String</a></div></div>"},{"info":{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/92e7648d19f24127919bcf3ff86eb0a43388824c/UnicodeBasic/Types.lean#L23-L24","name":"Unicode.max","line":23,"kind":"def","docLink":"./UnicodeBasic/Types.html#Unicode.max","doc":"Maximum valid code point value "},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./UnicodeBasic/Types.html#Unicode.max\"><span class=\"name\">Unicode</span>.<span class=\"name\">max</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#UInt32\">UInt32</a></div></div>"},{"info":{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/92e7648d19f24127919bcf3ff86eb0a43388824c/UnicodeBasic/Types.lean#L15-L21","name":"Unicode.instCoeStringSubstring_unicodeBasic","line":15,"kind":"def","docLink":"./UnicodeBasic/Types.html#Unicode.instCoeStringSubstring_unicodeBasic","doc":"Coercion from `String` to `Substring`\n\nThis coercion is in Batteries but not in Lean. It is scoped to `Unicode` here to avoid issues in\nlow-level packages that don't use Batteries.\n"},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./UnicodeBasic/Types.html#Unicode.instCoeStringSubstring_unicodeBasic\"><span class=\"name\">Unicode</span>.<span class=\"name\">instCoeStringSubstring_unicodeBasic</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Coe.html#Coe\">Coe</a> <a href=\"./Init/Prelude.html#String\">String</a> <a href=\"./Init/Prelude.html#Substring\">Substring</a></span></div></div>"},{"info":{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/92e7648d19f24127919bcf3ff86eb0a43388824c/UnicodeBasic/Types.lean#L6-L11","name":"Char.mkUnsafe","line":6,"kind":"def","docLink":"./UnicodeBasic/Types.html#Char.mkUnsafe","doc":"Low-level conversion from `UInt32` to `Char` (*unsafe*)\n\nThis function translates to a no-op in the compiler. However, it does not\ncheck whether the `UInt32` code is a valid `Char` value. Only use where it's\nknown for external reasons that the code is valid. "},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">unsafe def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./UnicodeBasic/Types.html#Char.mkUnsafe\"><span class=\"name\">Char</span>.<span class=\"name\">mkUnsafe</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#UInt32\">UInt32</a> → <a href=\"./Init/Prelude.html#Char\">Char</a></span></div></div>"}]}