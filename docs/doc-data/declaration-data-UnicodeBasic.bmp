{"name":"UnicodeBasic","instances":[],"imports":["Init","UnicodeBasic.Types","UnicodeBasic.TableLookup"],"declarations":[{"info":{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic#L1001-L1001","name":"Unicode.isAlpha","line":1001,"kind":"def","docLink":"./UnicodeBasic.html#Unicode.isAlpha","doc":"Check if alphabetic character\n\nGenerated by `GeneralCategory=L | GeneralCategory=Nl | Other_Alphabetic`.\n\nUnicode property: `Alphabetic` "},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./UnicodeBasic.html#Unicode.isAlpha\"><span class=\"name\">Unicode</span>.<span class=\"name\">isAlpha</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(char : <a href=\"./Init/Prelude.html#Char\">Char</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Bool\">Bool</a></div></div>"},{"info":{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic#L993-L998","name":"Unicode.isAlphabetic","line":993,"kind":"def","docLink":"./UnicodeBasic.html#Unicode.isAlphabetic","doc":"Check if alphabetic character\n\nGenerated by `GeneralCategory=L | GeneralCategory=Nl | Other_Alphabetic`.\n\nUnicode property: `Alphabetic` "},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./UnicodeBasic.html#Unicode.isAlphabetic\"><span class=\"name\">Unicode</span>.<span class=\"name\">isAlphabetic</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(char : <a href=\"./Init/Prelude.html#Char\">Char</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Bool\">Bool</a></div></div>"},{"info":{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic#L985-L985","name":"Unicode.isMath","line":985,"kind":"def","docLink":"./UnicodeBasic.html#Unicode.isMath","doc":"Check if mathematical symbol character\n\nGenerated by `GeneralCategory=Sm | Other_Math`.\n\nUnicode property: `Math` "},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./UnicodeBasic.html#Unicode.isMath\"><span class=\"name\">Unicode</span>.<span class=\"name\">isMath</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(char : <a href=\"./Init/Prelude.html#Char\">Char</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Bool\">Bool</a></div></div>"},{"info":{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic#L972-L977","name":"Unicode.isWhiteSpace","line":972,"kind":"def","docLink":"./UnicodeBasic.html#Unicode.isWhiteSpace","doc":"Check if white space character\n\nUnicode property: `White_Space`\n"},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./UnicodeBasic.html#Unicode.isWhiteSpace\"><span class=\"name\">Unicode</span>.<span class=\"name\">isWhiteSpace</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(char : <a href=\"./Init/Prelude.html#Char\">Char</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Bool\">Bool</a></div></div>"},{"info":{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic#L942-L961","name":"Unicode.getHexDigit?","line":942,"kind":"def","docLink":"./UnicodeBasic.html#Unicode.getHexDigit?","doc":"Get value of digit\n\nUnicode property: `Hex_Digit` "},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./UnicodeBasic.html#Unicode.getHexDigit?\"><span class=\"name\">Unicode</span>.<span class=\"name\">getHexDigit?</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(char : <a href=\"./Init/Prelude.html#Char\">Char</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Option\">Option</a> <span class=\"fn\">(<a href=\"./Init/Prelude.html#Fin\">Fin</a> <span class=\"fn\">16</span>)</span></span></div></div>"},{"info":{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic#L929-L936","name":"Unicode.isHexDigit","line":929,"kind":"def","docLink":"./UnicodeBasic.html#Unicode.isHexDigit","doc":"Check if character represents a digit in base 16\n\nUnicode property: `Hex_Digit` "},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./UnicodeBasic.html#Unicode.isHexDigit\"><span class=\"name\">Unicode</span>.<span class=\"name\">isHexDigit</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(char : <a href=\"./Init/Prelude.html#Char\">Char</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Bool\">Bool</a></div></div>"},{"info":{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic#L911-L923","name":"Unicode.getDecimalRange?","line":911,"kind":"def","docLink":"./UnicodeBasic.html#Unicode.getDecimalRange?","doc":"Get decimal digit range\n\nIf the character is part of a contiguous sequence representing the ten\ndecimal digits in order from 0 to 9, this function returns the first and\nlast characters from this range.\n\nUnicode properties:\n  `Numeric_Type=Decimal`\n  `Numeric_Value` "},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./UnicodeBasic.html#Unicode.getDecimalRange?\"><span class=\"name\">Unicode</span>.<span class=\"name\">getDecimalRange?</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(char : <a href=\"./Init/Prelude.html#Char\">Char</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Option\">Option</a> <span class=\"fn\">(<a href=\"./Init/Prelude.html#Char\">Char</a> <a href=\"./Init/Prelude.html#Prod\">×</a> <a href=\"./Init/Prelude.html#Char\">Char</a>)</span></span></div></div>"},{"info":{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic#L892-L899","name":"Unicode.isDecimal","line":892,"kind":"def","docLink":"./UnicodeBasic.html#Unicode.isDecimal","doc":"Check if character represents a decimal digit\n\nFor this property, a character must be part of a contiguous sequence\nrepresenting the ten decimal digits in order from 0 to 9.\n\nUnicode property: `Numeric_Type=Decimal` "},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./UnicodeBasic.html#Unicode.isDecimal\"><span class=\"name\">Unicode</span>.<span class=\"name\">isDecimal</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(char : <a href=\"./Init/Prelude.html#Char\">Char</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Bool\">Bool</a></div></div>"},{"info":{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic#L868-L883","name":"Unicode.getDigit?","line":868,"kind":"def","docLink":"./UnicodeBasic.html#Unicode.getDigit?","doc":"Get value of digit\n\nUnicode properties:\n`Numeric_Type=Digit`\n`Numeric_Value` "},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./UnicodeBasic.html#Unicode.getDigit?\"><span class=\"name\">Unicode</span>.<span class=\"name\">getDigit?</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(char : <a href=\"./Init/Prelude.html#Char\">Char</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Option\">Option</a> <span class=\"fn\">(<a href=\"./Init/Prelude.html#Fin\">Fin</a> <span class=\"fn\">10</span>)</span></span></div></div>"},{