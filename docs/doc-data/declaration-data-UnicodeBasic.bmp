r\n\nUnicode property: `Canonical_Combining_Class`\n"},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./UnicodeBasic.html#Unicode.getCanonicalCombiningClass\"><span class=\"name\">Unicode</span>.<span class=\"name\">getCanonicalCombiningClass</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">char</span> : <a href=\"./Init/Prelude.html#Char\">Char</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Nat\">Nat</a></div></div>"},{"info":{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/92e7648d19f24127919bcf3ff86eb0a43388824c/UnicodeBasic.lean#L600-L615","name":"Unicode.getTitleChar","line":600,"kind":"def","docLink":"./UnicodeBasic.html#Unicode.getTitleChar","doc":"Map character to titlecase\n\nThis function does not handle the case where the titlecase mapping would\nconsist of more than one character.\n\nUnicode property: `Simple_Titlecase_Mapping` "},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./UnicodeBasic.html#Unicode.getTitleChar\"><span class=\"name\">Unicode</span>.<span class=\"name\">getTitleChar</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">char</span> : <a href=\"./Init/Prelude.html#Char\">Char</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Char\">Char</a></div></div>"},{"info":{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/92e7648d19f24127919bcf3ff86eb0a43388824c/UnicodeBasic.lean#L583-L598","name":"Unicode.getUpperChar","line":583,"kind":"def","docLink":"./UnicodeBasic.html#Unicode.getUpperChar","doc":"Map character to uppercase\n\nThis function does not handle the case where the uppercase mapping would\nconsist of more than one character.\n\nUnicode property: `Simple_Uppercase_Mapping` "},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./UnicodeBasic.html#Unicode.getUpperChar\"><span class=\"name\">Unicode</span>.<span class=\"name\">getUpperChar</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">char</span> : <a href=\"./Init/Prelude.html#Char\">Char</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Char\">Char</a></div></div>"},{"info":{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/92e7648d19f24127919bcf3ff86eb0a43388824c/UnicodeBasic.lean#L565-L581","name":"Unicode.getLowerChar","line":565,"kind":"def","docLink":"./UnicodeBasic.html#Unicode.getLowerChar","doc":"Map character to lowercase\n\nThis function does not handle the case where the lowercase mapping would\nconsist of more than one character.\n\nUnicode property: `Simple_Lowercase_Mapping` "},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./UnicodeBasic.html#Unicode.getLowerChar\"><span class=\"name\">Unicode</span>.<span class=\"name\">getLowerChar</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">char</span> : <a href=\"./Init/Prelude.html#Char\">Char</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Char\">Char</a></div></div>"},{"info":{"sourceLink":"https://github.com/fgdorais/lean4-unicode-basic/blob/92e7648d19f24127919bcf3ff86eb0a43388824c/UnicodeBasic.lean#L546-L563","name":"Unicode.isCaseIgnorable.other","line":546,"kind":"def","docLink":"./UnicodeBasic.html#Unicode.isCaseIgnorable.other","doc":"Auxiliary data for `isCaseIgnorable`\n\nExtracted from UCD `auxiliary/WordBreakProperty.txt`. "},"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span cl